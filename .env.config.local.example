# ---------------------------------------
# Local-only overrides example
# Copy to .env.config.local and set real values
# ---------------------------------------

# ---------- Runtime mode ----------
VITE_DATA_SOURCE=flat
FEEDBACK_DATA_SOURCE=flat
EMERALD_UI_VARIANT=newUI
EMERALD_FEEDBACK_PANEL_STAY_OPEN=false

# ---------- API endpoints ----------
VITE_SYNTHESIS_API_BASE_URL=http://localhost:8794
API_PORT=8794

# ---------- Provider selection ----------
# Controls all provider-backed AI calls in this app.
# Accepted: anthropic | openai
# Default if omitted: anthropic
SYNTHESIS_API_PROVIDER=anthropic

# ---------- Provider API keys ----------
# Used when SYNTHESIS_API_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Used when SYNTHESIS_API_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here

# Optional model override (provider-specific default used when omitted)
SYNTHESIS_MODEL=

# ---------- Optional provider base URLs ----------
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01

# ---------- Synthesis access ----------
SYNTHESIS_PIN=1234
